object galvan {
    var sueldo = 15000
    method sueldo(_sueldo) { //setter
      sueldo = _sueldo
    }
}

object baigorria {
  const precioPorEmpanada = 15
  var cantEmpanadaVendidas = 0

  method sueldo () { 
    return cantEmpanadaVendidas * precioPorEmpanada  
  }
}

object gimenez {
    var fondo = 300.000

    method fondo(sueldo){
        fondo = fondo - sueldo
    }

}


